"----------------------------------------- General"
syntax enable
set t_co=256

set number

set termguicolors

"---------------------------------------- Tabs"
filetype plugin indent on
set expandtab
set shiftwidth=4
set tabstop=4
set softtabstop=4
set shiftround
set nowrap

set scrolloff=3
set sidescrolloff=5
set nocompatible
set backspace=2

"---------------------------------------- Visual"
set showmode
set laststatus=2
set showcmd
set modeline
set ruler
set title

